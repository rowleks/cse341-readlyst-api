    "/auth/google/token": {
      "post": {
        "tags": ["Auth"],
        "summary": "Exchange Google OAuth authorization code for JWT",
        "description": "Exchange Google OAuth code for a JWT token",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string",
                  "example": "Google authorization code"
                },
                "redirect_uri": {
                  "type": "string",
                  "example": "Redirect URI used in Google OAuth flow"
                },
                "code_verifier": {
                  "type": "string",
                  "example": "PKCE code verifier (optional)"
                },
                "grant_type": {
                  "type": "string",
                  "example": "authorization_code"
                }
              },
              "required": [
                "code",
                "redirect_uri",
                "code_verifier",
                "grant_type"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns JWT access token",
            "schema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "example": "object"
                },
                "properties": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "string"
                        },
                        "example": {
                          "type": "string",
                          "example": "eyJhbGciOiJIUzI1NiIs..."
                        }
                      }
                    },
                    "token_type": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "string"
                        },
                        "example": {
                          "type": "string",
                          "example": "Bearer"
                        }
                      }
                    }
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          }
        }
      }
    },
